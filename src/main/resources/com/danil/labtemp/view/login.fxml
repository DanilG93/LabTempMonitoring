<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.danil.labtemp.controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="LabTemp Login" textFill="WHITE">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="Korisničko ime:" textFill="#b5b5b5" />
                <TextField fx:id="usernameField" promptText="Unesite username" style="-fx-background-color: #3b3b3b; -fx-text-fill: white;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Lozinka:" textFill="#b5b5b5" />
                <PasswordField fx:id="passwordField" promptText="Unesite lozinku" style="-fx-background-color: #3b3b3b; -fx-text-fill: white;" />
            </children>
        </VBox>

        <Label fx:id="errorLabel" text="Greška" textFill="#ff6666" wrapText="true">
            <font>
                <Font size="12.0" />
            </font>
        </Label>

        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #00ffcc; -fx-text-fill: #2b2b2b; -fx-font-weight: bold;" text="Prijavi se">
            <font>
                <Font size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
    </children>
</VBox>